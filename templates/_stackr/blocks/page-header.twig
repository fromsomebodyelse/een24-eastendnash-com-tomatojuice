{% macro pageHeader(props = {
    backgroundImage: {src: '/static/images/header.jpg', width: '', height: '' },
}) %}

    <div class="bg-black">
        <div class="relative isolate overflow-hidden pt-14">
            {# Background Image #}
            <img class="absolute inset-0 -z-10 w-full h-full object-cover" src="{{ props.backgroundImage.src }}" alt="Historic East End Sign">
            
            {# BG Gradient #}
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-[#000] to-transparent opacity-50"></div>

            {# Mast Head #}
            <div class="relative mx-auto max-w-2xl py-20">
                {# Mast Head Content #}
                <div class="text-center">
                    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">East End<br/><span class="text-3xl tracking-wide leading-5"> Neighborhood Association</span></h1>
                </div>
            </div>
        </div>
    </div>
{% endmacro %}

{% macro pageHeaderMeetings(props = {
    headline: 'Lorem Ipsum',
    intro: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
}) %}
    <div>
        {% if (props.headline | default(null)) %}
            <h2 class="text-4xl font-semibold">{{ props.headline }}</h2>
        {% endif %}
        {% if (props.intro | default(null)) %}
            <p class="mt-3 text-lg">{{ props.intro }}</p>
        {% endif %}
    </div>
{% endmacro %}

{% macro pageHeaderEvents(props = {
    headline: 'Lorem Ipsum',
    intro: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.',
    filters: ['All', 'One', 'Two', 'Three'],
}) %}
    <div class="relative lg:flex px-container gap-10">
        <div class="flex flex-col w-2/5 mt-16 mb-10">
            <h2 class="text-4xl font-semibold">{{ props.headline }}</h2>
            <p class="mt-3 text-lg">{{ props.intro }}</p>
            <ul class="flex gap-5">
                {% for filter in props.filters %}
                    <li class="flex flex-col items-center justify-center">
                        <a href="#" class="flex items-center justify-center px-2 py-1 rounded-full border border-dashed border-black/50 hover:border-solid hover:bg-white/40 hover:fill-white transition-colors">
                            <span class="block text-md text-center leading-tight tracking-tight whitespace-nowrap">All</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endmacro %}
