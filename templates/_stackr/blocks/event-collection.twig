{% macro eventCollection(props = {
    headline: 'Lorem Ipsum',
    intro: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>',
    filters: ['One', 'Two'],
    eventEntries: [],
}) %}

    {% set filterMenuHtml %}
        <div class="flex items-center  gap-5">
            <span class="block">Filter By:</span>

            <ul class="flex gap-5 overflow-hidden">
                {% for filterItem in ['All'] | merge(props.filters) %}
                    <li class="flex flex-col items-center justify-center">
                        <a href="#" class="flex items-center justify-center px-2 py-1 min-w-12 rounded-full border border-dashed border-black/50 hover:border-solid hover:bg-black hover:text-white transition-colors">
                            <span class="block text-md text-center leading-tight tracking-tight whitespace-nowrap">{{ filterItem }}</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endset %}

    <div class="relative lg:flex px-container gap-10">
        <div class="lg:w-3/5 mt-16 mb-10">
            <h2 class="text-4xl font-semibold">{{ props.headline }}</h2>
            <div class="mt-3 text-lg">{{ props.intro | raw }}</div>
        </div>
    </div>

    <div class="h-px bg-black/20"></div>

    <div class="px-container py-6">{{ filterMenuHtml }}</div>

    <div class="h-px bg-black/20"></div>

    <ol debug-red class="mt-6 space-y-4">
        {% for event in props.eventEntries %}
            {% set hasDateAndLocation = event.startDate != null and event.location %}

            <li>
                <div class="flex px-container py-4 gap-5">
                    {# Date/Title #}
                    <span class="block lg:w-3/12 pt-4 text-2xl">
                        <time class="text-xl font-semibold" datetime="{{ event.startDate | date('c') }}">
                            <span class="">{{ event.startDate | date('F') }}</span>
                            <span class="">, </span>
                            <span class="">{{ event.startDate | date('jS') }}</span>
                        </time>
                        
                        <p class="text-lg">{{ event.title }}</p>
                    </span>

                    <div class="grow lg:flex">
                        {# Image #}
                        <div debug-red class="relative w-full lg:w-2/12 lg:mr-10 aspect-square overflow-hidden">
                            {% for image in event.images %}
                                <div class="absolute w-full aspect-square bg-black rounded-md border-2 border-[--color-off-white] overflow-hidden"
                                    style="z-index: {{ 3 - loop.index }}; margin-left: {{ "#{loop.index0 * 10}%;" }}"
                                >
                                    <img class="w-full h-auto" src="{{ image.url() }}">
                                </div>
                            {% endfor %}
                        </div>

                        {# Details #}
                        <div class="leading-relaxed lg:ml-10">
                            
                            {# Caption #}
                            <p class="text-gray-800 text-md font-semibold">Trash Kitties - Community Litter Pickups!</p>
                            
                            {# Summary #}
                            <div class="prose text-gray-500 mt-1 mb-4">{{ event.summaryTextHtml }}</div>

                            {# Location/Website #}
                            <div class="flex-col lg:flex-row gap-4 text-gray-600">
                                {% set location = event.location %}
                                {% set website = 'https://www.tomatoartfest.com/' %}

                                {% if location %}
                                    <span class="flex items-center gap-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                                            <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                        </svg>
                                        {{ location.addressLine1 }}, {{ location.locality }}, {{ location.administrativeArea }} {{ location.postalCode }}
                                    </span>
                                {% endif %}

                                {% if website %}
                                    <span class="flex items-center gap-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                                            <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM6.262 6.072a8.25 8.25 0 1 0 10.562-.766 4.5 4.5 0 0 1-1.318 1.357L14.25 7.5l.165.33a.809.809 0 0 1-1.086 1.085l-.604-.302a1.125 1.125 0 0 0-1.298.21l-.132.131c-.439.44-.439 1.152 0 1.591l.296.296c.256.257.622.374.98.314l1.17-.195c.323-.054.654.036.905.245l1.33 1.108c.32.267.46.694.358 1.1a8.7 8.7 0 0 1-2.288 4.04l-.723.724a1.125 1.125 0 0 1-1.298.21l-.153-.076a1.125 1.125 0 0 1-.622-1.006v-1.089c0-.298-.119-.585-.33-.796l-1.347-1.347a1.125 1.125 0 0 1-.21-1.298L9.75 12l-1.64-1.64a6 6 0 0 1-1.676-3.257l-.172-1.03Z" clip-rule="evenodd" />
                                        </svg>
                                        <a class="underline" href="https://www.tomatoartfest.com/">tomatoartfest.com</a>
                                    </span>
                                {% endif %}
                            </div>

                            
                        </div>
                    </div>
                </div>
            </li>
        {% endfor %}
    </ol>
{% endmacro %}
